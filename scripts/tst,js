$(document).ready(function () {
  //$("LINK[href*='app-assets/css/style.css']").remove();
  const d = new Date();
  let customcourierName = "";
  $(".Courier").change(function () {
    var sel = document.getElementById("courierName");
    customcourierName = sel.options[sel.selectedIndex].text;
  });

  var today = new Date();
  var date =
    today.getFullYear() + "-" + (today.getMonth() + 1) + "-" + today.getDate();
  var time =
    today.getHours() + ":" + today.getMinutes() + ":" + today.getSeconds();
  var dateTime = date + " " + time;
  $("#orders-list").DataTable({
    columnDefs: [{ orderable: false, targets: 0 }],
    aaSorting: [[1, "dec"]],
    order: [[1, "dec"]],
    dom: "Blfrtip",
    bPaginate: false,
    buttons: [
      {
        extend: "print",
        text: "Print Sheet",
        footer: true,
        className: "btn btn-primary",
        textColor: "#fff",
        customize: function (win) {
          $(win.document.body)
            .find(".printheader")
            .prepend("Courier: " + customcourierName + "<br>");
        },
        repeatingHead: {
          title: '<span class="printheader">Date: ' + dateTime + "</span>",
        },
        attr: {
          id: "printButton",
        },
      },
      {
        extend: "csvHtml5",
        text: "Export to CSV",
        className: "btn btn-primary",
        textColor: "#fff",
        attr: { id: "csvButton" },
      },
    ],
  });
  var table = $("#orders-list").DataTable();
  $("#orders-list").on("click", ".removeButton", function () {
    //console.log($(this).parent());
    table.row($(this).parents("tr")).remove().draw(false);
  });
  table.buttons().container().appendTo($("#sheetButtons"));
  document.getElementById("printButton").disabled = true;
  document.getElementById("csvButton").disabled = true;
  $(".Courier").change(function () {
    var sel = document.getElementById("courierName");
    customcourierName = sel.options[sel.selectedIndex].text;
  });
});
var selectedIds = [];
function disableEnter(button) {
  button.addEventListener("keypress", function (event) {
    if (event.key === "Enter") {
      //alert(event.key  + " " + event.which);
      event.preventDefault();
    }
  });
}
function findOrders() {
  var orderId = document.getElementById("orderId").value;
  if (orderId == "") {
    alert("The order id cannot be blank!");
  } else if (selectedIds.includes(orderId)) {
    alert("Duplicated order id!");
  } else {
    var xhttp = new XMLHttpRequest();
    xhttp.onreadystatechange = function () {
      if (this.readyState == 4 && this.status == 200) {
        var order = this.responseText;
        if (order == "No such order exists") {
          document.getElementById("orderError").textContent =
            "No such order exists";
          document.getElementById("orderError").style.display = "block";
        } else if (order == "Order id is invalid") {
          document.getElementById("orderError").textContent =
            "Order id is invalid";
          document.getElementById("orderError").style.display = "block";
        } else if (isJson(order)) {
          document.getElementById("orderError").style.display = "none";
          order = JSON.parse(order);
          var table = $("#orders-list").DataTable();
          table.row.add(order).draw();
          document.getElementById("orderId").value = "";
          selectedIds.push(orderId);
        } else {
          document.getElementById("orderError").textContent =
            "Something went wrong please try again";
          document.getElementById("orderError").style.display = "block";
        }
        //console.log(order);
      }
    };
    xhttp.open("POST", "app-assets/php/courierSheet.php", true);
    xhttp.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    xhttp.send("orderId=" + orderId);
    //selectedIds = []; // Clear the selectedIds array
  }
}
function assignCoureir(checkbox) {
  var courierName = "courierId=" + document.getElementById("courierName").value;
  if (selectedIds == "") {
    alert("You have to select orders to assign!");
  } else if (courierName == "") {
    alert("You have to select courier name!");
  } else {
    selectedIds.push(courierName);
    //console.log(selectedIds);
    var xhttp = new XMLHttpRequest();
    xhttp.onreadystatechange = function () {
      if (this.readyState == 4 && this.status == 200) {
        document.getElementById("printButton").disabled = false;
        document.getElementById("csvButton").disabled = false;
        alert("Assigned successfully!");
      }
    };
    xhttp.open("POST", "app-assets/php/assignCoureir.php", true);
    xhttp.setRequestHeader("Content-type", "application/x-www-form-urlencoded");
    xhttp.send("selectedIds=" + selectedIds);
    //selectedIds = []; // Clear the selectedIds array
  }
}
function isJson(str) {
  try {
    JSON.parse(str);
  } catch (e) {
    return false;
  }
  return true;
}
